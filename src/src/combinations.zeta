 if indices [i] == self.pool.len() - 1 { self.pool.get_next(); }
 while indices [i] == i + self.pool.len() - indices.len() { if i > 0 { i -= 1; } else { return true; } }
 indices [i] += 1;
 for j in i + 1 .. indices.len() { indices [j] = indices [j - 1] + 1; }

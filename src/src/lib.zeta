 fn process_results<F, T, E, R>(self, processor: F) -> Result<R, E> where Self: Iterator<_> + Sized, F: FnOnce;
 fn merge<J>(self, other: J) -> Merge<Self, J::IntoIter> where Self: Sized, Self::Item: PartialOrd, J: IntoIterator<_>;
 fn merge_by<J, F>(self, other: J, is_first: F) -> MergeBy<Self, J::IntoIter, F> where Self: Sized, J: IntoIterator<_>, F: FnMut;
 fn merge_join_by<J, F, T>(self, other: J, cmp_fn: F) -> MergeJoinBy<Self, J::IntoIter, F> where J: IntoIterator, F: FnMut, Self: Sized;
 fn kmerge(self) -> KMerge<IntoIterator::IntoIter> where Self: Sized, Self::Item: IntoIterator, IntoIterator::Item: PartialOrd;
 fn kmerge_by<F>(self, first: F) -> KMergeBy<IntoIterator::IntoIter, F> where Self: Sized, Self::Item: IntoIterator, F: FnMut;

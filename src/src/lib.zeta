#[macro_export] #[doc = " [Chain][`chain`] zero or more iterators together into one sequence."] #[doc = ""] #[doc = " The comma-separated arguments must implement [`IntoIterator`]."] #[doc = " The final argument may be followed by a trailing comma."] #[doc = ""] #[doc = " [`chain`]: Iterator::chain"] #[doc = ""] #[doc = " # Examples"] #[doc = ""] #[doc = " Empty invocations of `chain!` expand to an invocation of [`std::iter::empty`]:"] #[doc = " ```"] #[doc = " use std::iter;"] #[doc = " use itertools::chain;"] #[doc = ""] #[doc = " let _: iter::Empty<()> = chain!();"] #[doc = " let _: iter::Empty<i8> = chain!();"] #[doc = " ```"] #[doc = ""] #[doc = " Invocations of `chain!` with one argument expand to [`arg.into_iter()`](IntoIterator):"] #[doc = " ```"] #[doc = " use std::ops::Range;"] #[doc = " use itertools::chain;"] #[doc = " let _: <Range<_> as IntoIterator>::IntoIter = chain!(2..6); // trailing comma optional!"] #[doc = " let _: <&[_] as IntoIterator>::IntoIter = chain!(&[2, 3, 4]);"] #[doc = " ```"] #[doc = ""] #[doc = " Invocations of `chain!` with multiple arguments [`.into_iter()`](IntoIterator) each"] #[doc = " argument, and then [`chain`] them together:"] #[doc = " ```"] #[doc = " use std::{iter::*, slice};"] #[doc = " use itertools::{assert_equal, chain};"] #[doc = ""] #[doc = " // e.g., this:"] #[doc = " let with_macro: Chain<Chain<Once<_>, Take<Repeat<_>>>, slice::Iter<_>> ="] #[doc = " chain![once(&0), repeat(&1).take(2), &[2, 3, 5],];"] #[doc = ""] #[doc = " // ...is equivalent to this:"] #[doc = " let with_method: Chain<Chain<Once<_>, Take<Repeat<_>>>, slice::Iter<_>> ="] #[doc = " once(&0)"] #[doc = " .chain(repeat(&1).take(2))"] #[doc = " .chain(&[2, 3, 5]);"] #[doc = ""] #[doc = " assert_equal(with_macro, with_method);"] #[doc = " ```"] macro_rules ! chain { () => { $ crate::__std_iter::empty() }; ($ first: expr $ (, $ rest: expr) * $ () ?) => { { let iter = $ crate::__std_iter::IntoIterator::into_iter($ first); $ (let iter = $ crate::__std_iter::Iterator::chain(iter, $ crate::__std_iter::IntoIterator::into_iter($ rest));) * iter } }; }
/// An [`Iterator`] blanket implementation that provides extra adaptors and
/// methods.
/// 
/// This trait defines a number of methods. They are divided into two groups:
/// 
/// * *Adaptors* take an iterator and parameter as input, and return
/// a new iterator value. These are listed first in the trait. An example
/// of an adaptor is [`.interleave()`](Itertools::interleave)
/// 
/// * *Regular methods* are those that don't return iterators and instead
/// return a regular value of some other kind.
/// [`.next_tuple()`](Itertools::next_tuple) is an example and the first regular
/// method in the list.
pub trait Itertools {
 fn interleave<J>(self, other: J) -> Interleave<Self, J::IntoIter> where J: IntoIterator<_>, Self: Sized;
 fn interleave_shortest<J>(self, other: J) -> InterleaveShortest<Self, J::IntoIter> where J: IntoIterator<_>, Self: Sized;
 fn intersperse(self, element: Self::Item) -> Intersperse<Self> where Self: Sized, Self::Item: Clone;
 fn intersperse_with<F>(self, element: F) -> IntersperseWith<Self, F> where Self: Sized, F: FnMut;
 fn get<R>(self, index: R) -> R::Output where Self: Sized, R: traits::IteratorIndex<Self>;
 fn zip_longest<J>(self, other: J) -> ZipLongest<Self, J::IntoIter> where J: IntoIterator, Self: Sized;
 fn zip_eq<J>(self, other: J) -> ZipEq<Self, J::IntoIter> where J: IntoIterator, Self: Sized;
 fn batching<B, F>(self, f: F) -> Batching<Self, F> where F: FnMut, Self: Sized;
 fn chunk_by<K, F>(self, key: F) -> ChunkBy<K, Self, F> where Self: Sized, F: FnMut, K: PartialEq;
 fn group_by<K, F>(self, key: F) -> ChunkBy<K, Self, F> where Self: Sized, F: FnMut, K: PartialEq;
 fn chunks(self, size: usize) -> IntoChunks<Self> where Self: Sized;
 fn tuple_windows<T>(self) -> TupleWindows<Self, T> where Self: Sized + Iterator<_>, T: traits::HomogeneousTuple, T::Item: Clone;
 fn circular_tuple_windows<T>(self) -> CircularTupleWindows<Self, T> where Self: Sized + Clone + Iterator<_> + ExactSizeIterator, T: tuple_impl::TupleCollect + Clone, T::Item: Clone;
 fn tuples<T>(self) -> Tuples<Self, T> where Self: Sized + Iterator<_>, T: traits::HomogeneousTuple;
 fn tee(self) ->(Tee<Self>, Tee<Self>) where Self: Sized, Self::Item: Clone;
 fn map_into<R>(self) -> MapInto<Self, R> where Self: Sized, Self::Item: Into<R>;
 fn map_ok<F, T, U, E>(self, f: F) -> MapOk<Self, F> where Self: Iterator<_> + Sized, F: FnMut;
 fn filter_ok<F, T, E>(self, f: F) -> FilterOk<Self, F> where Self: Iterator<_> + Sized, F: FnMut;
 fn filter_map_ok<F, T, U, E>(self, f: F) -> FilterMapOk<Self, F> where Self: Iterator<_> + Sized, F: FnMut;
